{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FinNews research feature row v1",
  "type": "object",
  "required": [
    "contract_version",
    "calendar_id",
    "calendar_version",
    "session_date",
    "decision_cutoff_at",
    "ticker",
    "company_id",
    "window_sessions",
    "feature_schema_version",
    "information_cutoff_at",
    "generated_from_article_count",
    "lineage_row_id",
    "synthetic_data",
    "generated_by_version",
    "news_count",
    "has_news"
  ],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "session_date": { "type": "string", "format": "date" },
    "decision_cutoff_at": { "type": "string", "format": "date-time" },
    "window_sessions": { "type": "integer", "minimum": 1 },
    "news_count": { "type": "integer", "minimum": 0 },
    "has_news": { "type": "boolean" },
    "mean_sentiment_score": { "type": ["number", "null"] },
    "lineage_row_id": { "type": "string" }
  },
  "additionalProperties": true
}
