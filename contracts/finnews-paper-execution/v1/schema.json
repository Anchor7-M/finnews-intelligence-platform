{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Paper execution instruction contract only. This is never a broker order.",
  "properties": {
    "asset_id": { "type": "string" },
    "contract_name": { "const": "finnews-paper-execution-v1" },
    "contract_version": { "const": "1.0.0" },
    "created_at": { "format": "date-time", "type": "string" },
    "currency": { "type": "string" },
    "decision_time": { "format": "date-time", "type": "string" },
    "direction": { "enum": ["positive", "negative", "mixed", "uncertain"], "type": "string" },
    "expires_at": { "format": "date-time", "type": "string" },
    "idempotency_key": { "type": "string" },
    "manual_approval_state": {
      "enum": ["pending_review", "approved", "rejected", "expired"],
      "type": "string"
    },
    "not_investment_advice": { "const": true },
    "paper_notional": { "type": "string" },
    "paper_order_id": { "type": "string" },
    "paper_quantity_units": { "type": "string" },
    "paper_side": { "enum": ["long", "flat", "reduce"], "type": "string" },
    "payload_hash": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
    "reason_codes": { "items": { "type": "string" }, "type": "array" },
    "risk_decision": {
      "enum": [
        "approved_for_paper",
        "requires_manual_review",
        "rejected",
        "expired",
        "duplicate",
        "kill_switch_active"
      ],
      "type": "string"
    },
    "risk_policy_id": { "type": "string" },
    "signal_id": { "type": "string" },
    "synthetic_data": { "const": true }
  },
  "required": [
    "paper_order_id",
    "contract_name",
    "contract_version",
    "created_at",
    "signal_id",
    "asset_id",
    "direction",
    "paper_side",
    "decision_time",
    "expires_at",
    "paper_quantity_units",
    "paper_notional",
    "currency",
    "risk_policy_id",
    "risk_decision",
    "manual_approval_state",
    "idempotency_key",
    "synthetic_data",
    "not_investment_advice",
    "reason_codes",
    "payload_hash"
  ],
  "title": "finnews-paper-execution-v1",
  "type": "object",
  "x-forbidden-fields": [
    "broker_server",
    "account_id",
    "login",
    "password",
    "terminal_path",
    "mt5_symbol",
    "order_ticket",
    "position_id",
    "real_lot_size",
    "leverage",
    "margin",
    "stop_loss",
    "take_profit",
    "order_type",
    "execution_flag",
    "order_check",
    "order_send"
  ]
}
