{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://finnews.local/contracts/finnews-market-bars/v1/bar.schema.json",
  "title": "finnews-market-bars-v1 bar row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "asset_id",
    "provider_symbol",
    "bar_start_at",
    "bar_end_at",
    "timezone",
    "open",
    "high",
    "low",
    "close",
    "volume",
    "source_profile",
    "first_seen_at",
    "available_at",
    "synthetic_data",
    "schema_version"
  ],
  "properties": {
    "bar_id": { "type": "string", "minLength": 1 },
    "asset_id": { "type": "string", "minLength": 1 },
    "provider_symbol": { "type": "string", "minLength": 1 },
    "session_date": { "type": "string", "format": "date" },
    "bar_start_at": { "type": "string", "format": "date-time" },
    "bar_end_at": { "type": "string", "format": "date-time" },
    "timezone": { "const": "UTC" },
    "open": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "high": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "low": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "close": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "volume": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "quote_volume": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "source_profile": { "type": "string", "minLength": 1 },
    "first_seen_at": { "type": "string", "format": "date-time" },
    "available_at": { "type": "string", "format": "date-time" },
    "synthetic_data": { "type": "boolean" },
    "schema_version": { "const": "finnews-market-bars-v1" }
  }
}
