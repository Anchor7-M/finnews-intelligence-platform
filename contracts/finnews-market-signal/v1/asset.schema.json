{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FinNews canonical asset row v1",
  "type": "object",
  "required": [
    "asset_id",
    "display_name",
    "asset_class",
    "country_region",
    "status",
    "synthetic",
    "provenance",
    "schema_version"
  ],
  "properties": {
    "id": { "type": "string" },
    "asset_id": { "type": "string" },
    "display_name": { "type": "string" },
    "asset_class": {
      "enum": [
        "us_equity",
        "etf",
        "equity_index",
        "fx",
        "precious_metal",
        "commodity",
        "futures_root",
        "futures_contract",
        "crypto_asset",
        "macro_indicator",
        "interest_rate"
      ]
    },
    "canonical_symbol": { "type": ["string", "null"] },
    "home_venue": { "type": ["string", "null"] },
    "country_region": { "type": "string" },
    "base_currency": { "type": ["string", "null"] },
    "quote_currency": { "type": ["string", "null"] },
    "parent_asset_id": { "type": ["string", "null"] },
    "expiry": { "type": ["string", "null"] },
    "contract_metadata": { "type": "object" },
    "status": { "enum": ["active", "inactive"] },
    "synthetic": { "const": true },
    "provenance": { "type": "object" },
    "schema_version": { "const": "cross-asset-v1" }
  },
  "additionalProperties": false
}
